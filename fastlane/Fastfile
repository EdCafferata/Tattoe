default_platform(:ios)

platform :ios do
  desc "Bouw en upload naar TestFlight"
  lane :beta do
    ENV["DEVELOPER_DIR"] = "/Applications/Xcode.app/Contents/Developer"

    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"]
    )

    # Buildnummer = tijdstempel (altijd oplopend, geen AGV nodig)
    build_nr = Time.now.strftime("%Y%m%d%H%M")

    build_app(
      scheme:        "tattoe",
      project:       "Tattoe.xcodeproj",
      export_method: "app-store",
      configuration: "Release",
      xcargs:        "CURRENT_PROJECT_VERSION=#{build_nr}"
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload metadata naar App Store Connect"
  lane :metadata do
    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"]
    )

    deliver(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: false,
      skip_binary_upload: true,
      submit_for_review: false,
      force: true
    )
  end
end
